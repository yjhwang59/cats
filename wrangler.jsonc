{
  // Cloudflare Pages + D1（靜態站 + functions/api）。GitHub Actions 用 pages deploy；勿用 npx wrangler deploy。
  "name": "cat-git",
  "compatibility_date": "2025-09-27",
  "pages_build_output_dir": ".",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "catsd1_db",
      "database_id": "6dd3e42a-9f1c-491d-a1b0-bd2da79e5fd0"
    }
  ]
}
